{
  "name": "@keremmert/react-world-map",
  "version": "1.0.3",
  "description": "Customizable SVG-based interactive world map React library",
  "keywords": [
    "react",
    "react-map",
    "world-map",
    "react-world-map",
    "interactive-map",
    "svg-map",
    "react-svg-map",
    "geojson-map",
    "react-visualization",
    "map-component"
  ],
  "license": "MIT",
  "author": "Kerem Mert",
  "homepage": "https://github.com/kerem37mert/react-world-map#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/kerem37mert/react-world-map.git"
  },
  "bugs": {
    "url": "https://github.com/kerem37mert/react-world-map/issues"
  },
  "main": "dist/react-world-map.cjs.js",
  "module": "dist/react-world-map.es.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/react-world-map.es.js",
      "require": "./dist/react-world-map.cjs.js",
      "types": "./dist/index.d.ts"
    },
    "./data/states": {
      "types": "./dist/data/states-default.geo.json.d.ts",
      "default": "./dist/data/states-default.geo.json"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite serve example --config vite.example.config.ts",
    "build": "vite build",
    "test": "vitest",
    "lint": "eslint src --ext .ts,.tsx",
    "generate-data": "node scripts/generate-geo-data.mjs"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "dependencies": {
    "d3-geo": "^3.1.0",
    "d3-selection": "^3.0.0",
    "d3-zoom": "^3.0.0"
  },
  "devDependencies": {
    "@types/d3-geo": "^3.1.0",
    "@types/d3-selection": "^3.0.0",
    "@types/d3-zoom": "^3.0.0",
    "@types/geojson": "^7946.0.14",
    "@types/node": "^25.3.5",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.0.0",
    "vitest": "^1.0.0"
  }
}